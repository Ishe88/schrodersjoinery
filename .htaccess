# Prioritize static index.html over WordPress index.php (prevents PHP crashes)
DirectoryIndex index.html index.php

# ----------------------------------------------------------------------
# Schröder's Joinery - Apache Rewrite & Redirect Rules
# ----------------------------------------------------------------------
RewriteEngine On
RewriteBase /

# 1. Force Canonical Domain (redirect non-www to www)
RewriteCond %{HTTP_HOST} ^schrodersjoinery\.co\.za [NC]
RewriteRule ^(.*)$ https://www.schrodersjoinery.co.za/$1 [R=301,L]

# 2. Redirect index.html requests to root / (keeps URL bar clean)
RewriteCond %{THE_REQUEST} ^[A-Z]{3,9}\ /index\.html\ HTTP/ [NC]
RewriteRule ^index\.html$ https://www.schrodersjoinery.co.za/ [R=301,L]

# 3. Redirect direct requests for *.html to extensionless URLs
RewriteCond %{THE_REQUEST} ^[A-Z]{3,9}\ /([^.]+)\.html\ HTTP/ [NC]
RewriteRule ^([^.]+)\.html$ https://www.schrodersjoinery.co.za/$1 [R=301,L]

# 4. Internally map extensionless URLs to their HTML files
# Prioritizes mapping to xxx.html even if a directory named xxx exists (like /portfolio)
RewriteCond %{DOCUMENT_ROOT}/$1.html -f
RewriteRule ^([^/]+)/?$ $1.html [L]

# 5. Mappings for Consolidated WordPress Pages to Tab Anchors
RewriteRule ^kitchens/?$ https://www.schrodersjoinery.co.za/portfolio#kitchens [R=301,NE,L]
RewriteRule ^bedrooms/?$ https://www.schrodersjoinery.co.za/portfolio#cabinetry [R=301,NE,L]
RewriteRule ^bespoke-furniture/?$ https://www.schrodersjoinery.co.za/portfolio#furniture [R=301,NE,L]
RewriteRule ^bathrooms/?$ https://www.schrodersjoinery.co.za/portfolio#bathrooms [R=301,NE,L]
RewriteRule ^interiors/?$ https://www.schrodersjoinery.co.za/portfolio#interiors [R=301,NE,L]
RewriteRule ^offices/?$ https://www.schrodersjoinery.co.za/portfolio#offices [R=301,NE,L]

# 6. Redirects for Core WordPress Pages to Clean URLs
RewriteRule ^services/?$ https://www.schrodersjoinery.co.za/services [R=301,L]
RewriteRule ^contact-us/?$ https://www.schrodersjoinery.co.za/contact [R=301,L]
RewriteRule ^portfolio/?$ https://www.schrodersjoinery.co.za/portfolio [R=301,L]
RewriteRule ^privacy-policy/?$ https://www.schrodersjoinery.co.za/privacy-policy [R=301,L]

# 7. Redirects for WordPress Sections Merged to Homepage sections
RewriteRule ^our-story/?$ https://www.schrodersjoinery.co.za/#storySection [R=301,NE,L]
RewriteRule ^materials/?$ https://www.schrodersjoinery.co.za/services#materialsSection [R=301,NE,L]

# 8. Redirect old WordPress Sitemap Indexes to Static Sitemap
Redirect 301 /sitemap_index.xml /sitemap.xml
Redirect 301 /page-sitemap.xml /sitemap.xml
Redirect 301 /post-sitemap.xml /sitemap.xml
